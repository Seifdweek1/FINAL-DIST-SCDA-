NODE_ENV=development
PORT=3002
HOST=0.0.0.0

JWT_SECRET=replace-with-long-random-string
DATABASE_URL=postgresql://scda_user:scda_password_placeholder@postgres:5432/scda_db

# 64 hex chars (32 bytes) — AES-256-GCM key material
ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Use same user/pass as docker-compose RabbitMQ (Task 16 — no guest/guest)
RABBITMQ_URL=amqp://scda_mq:scda_mq_dev_change_me@rabbitmq:5672

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=20971520

# Optional comma-separated lists
# ALLOWED_MIME_TYPES=application/pdf,text/plain
# ALLOWED_EXTENSIONS=.pdf,.txt,.doc,.docx
# DOCUMENT_JOBS_QUEUE=document.jobs
# AUDIT_LOG_FILE=./uploads/.audit/documents.jsonl

INTERNAL_API_KEY=replace-with-internal-key

# Central audit PostgreSQL API (dual-write from document-service; auth posts login events)
AUDIT_SERVICE_URL=http://audit-service:3004
