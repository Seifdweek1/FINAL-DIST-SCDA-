NODE_ENV=development
PORT=3003
HOST=0.0.0.0

# PostgreSQL (same DB as auth/documents/audit — required for persisted chat)
DATABASE_URL=postgresql://scda_user:scda_password_placeholder@localhost:5432/scda_db

# Optional: max characters per chat user message (default 8000)
# CHAT_MAX_MESSAGE_LENGTH=8000

# Qdrant REST base URL (no trailing slash)
QDRANT_URL=http://localhost:6333
# Optional for Qdrant Cloud / secured instances
QDRANT_API_KEY=

# Collection name (created on startup if missing)
QDRANT_COLLECTION=scda_ai

# Vector size for hash-simulated embeddings (must match existing collection if you change it)
EMBEDDING_DIM=384

# Same secret as auth-service (HS256 JWT)
JWT_SECRET=replace-with-same-jwt-secret-as-auth-service

# Same key as audit-service INTERNAL_API_KEY (header X-Internal-Api-Key)
INTERNAL_API_KEY=replace-with-internal-key

# Base URL of audit-service (no trailing slash). In Docker Compose use http://audit-service:3004
AUDIT_SERVICE_URL=http://localhost:3004
