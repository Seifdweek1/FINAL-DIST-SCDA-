# Copy to `.env` next to docker-compose.yml (gitignored) so Compose can substitute variables.
#
# Full-stack minimum (Docker Compose):
#   JWT_SECRET          — HS256 secret shared by auth, document, audit, ai services
#   INTERNAL_API_KEY    — audit ingestion + auth/document clients posting to audit-service
#   ENCRYPTION_KEY      — document-service: exactly 64 hex chars (32 bytes) for AES-256-GCM
#
# RabbitMQ (Task 16 — no guest/guest): user/pass must match RABBITMQ_URL below.
#   Defaults in docker-compose.yml use scda_mq / scda_mq_dev_change_me unless you override.
#
# Optional overrides:
#   JWT_EXPIRES_IN, BCRYPT_ROUNDS, QDRANT_URL, QDRANT_API_KEY, QDRANT_COLLECTION,
#   EMBEDDING_DIM, MAX_FILE_SIZE, AUDIT_SERVICE_URL, CHAT_MAX_MESSAGE_LENGTH (ai-service chat message max, default 8000)
#
# TLS for nginx-api-gateway — generate nginx/certs/*.pem (see root README).

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

DATABASE_URL=postgresql://scda_user:scda_password_placeholder@postgres:5432/scda_db

ENCRYPTION_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Broker credentials (must match rabbitmq service in docker-compose.yml)
RABBITMQ_USER=scda_mq
RABBITMQ_PASS=scda_mq_dev_change_me
RABBITMQ_URL=amqp://scda_mq:scda_mq_dev_change_me@rabbitmq:5672

INTERNAL_API_KEY=replace-with-strong-random-internal-key

AUDIT_SERVICE_URL=http://audit-service:3004

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=scda_ai
QDRANT_API_KEY=

EMBEDDING_DIM=384
MAX_FILE_SIZE=20971520

# OAuth (auth-service) — see docs/OAUTH.md
OAUTH_CALLBACK_BASE_URL=https://localhost
OAUTH_FRONTEND_REDIRECT_URL=https://localhost/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
