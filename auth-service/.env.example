NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL (use host `postgres` inside Docker Compose)
DATABASE_URL=postgresql://scda_user:scda_password_placeholder@postgres:5432/scda_db

# JWT — required; use a long random string in real deployments
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=15m

BCRYPT_ROUNDS=12

# Central audit (POST /api/audit/log). If both are set, login/register emit audit rows.
INTERNAL_API_KEY=replace-with-internal-key
AUDIT_SERVICE_URL=http://audit-service:3004

# OAuth (Task 4) — set at least one provider; see docs/OAUTH.md
OAUTH_CALLBACK_BASE_URL=https://localhost
OAUTH_FRONTEND_REDIRECT_URL=https://localhost/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
